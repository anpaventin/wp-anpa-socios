# ANPA Socios plugin — repo-level .gitignore (nando/wp-anpa-socios)

# Dev dependencies (phpunit etc.) — not shipped
/vendor/
/node_modules/

# PHPUnit caches
.phpunit.result.cache
.phpunit.cache

# Local test/scratch output
out.txt
*.log
/nul

# Local pre-deploy backups — preserve on disk, never publish
/bak/

# Local planning / agent artefacts (not shipped in the public plugin ZIP/repo)
/AGENTS.md
/IDEA.md
/openspec/
/.hermes/
/.agents/
/.claude/
/.sync/
/.atl/
/CLAUDE.md
/AGENTS.local.md
/TODO.local.md
/notes.local.md
/wp-content/

# Future local development artefacts: keep SDDs, agent scratchpads, downloaded
# WordPress trees, migration sandboxes and other non-plugin work outside GitHub.
*.local.md
*.scratch.md
*.tmp.md
*.bak
*.zip

# OS / editor
.DS_Store
Thumbs.db
*.swp
